# ╔══════════════════════════════════════════════════════╗
# ║     sᴇᴄʀᴇᴛ ғɪʟᴇ sᴛᴏʀɪɴɢ ʙᴏᴛ — ENVIRONMENT CONFIG  ║
# ╚══════════════════════════════════════════════════════╝

# — bot credentials
BOT_TOKEN=your_bot_token_here

# — owner & admin ids (comma-separated)
OWNER_ID=123456789
ADMIN_IDS=123456789,987654321

# — mongodb
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/secretfilebot
DB_NAME=secretfilebot

# — primary storage channel (private channel where files are stored)
STORAGE_CHANNEL_ID=-1001234567890

# — multi-channel storage (comma-separated channel IDs for load distribution)
# Files are distributed randomly across all channels, boosting storage power.
# You can add 3-4 channels here. Leave empty to use only STORAGE_CHANNEL_ID.
# Example: STORAGE_CHANNEL_IDS=-1001111111111,-1002222222222,-1003333333333
STORAGE_CHANNEL_IDS=

# — log channel (private channel for system logs)
LOG_CHANNEL_ID=-1009876543210

# — required join channels (comma-separated usernames without @)
# Leave empty to disable force-join requirement
REQUIRED_CHANNELS=secretsbotz

# — backup channels (comma-separated telegram chat IDs)
# Backup JSON will be sent to ALL of these channels on each scheduled backup.
# Example: BACKUP_CHANNEL_IDS=-1001111111111,-1002222222222
BACKUP_CHANNEL_IDS=

# — vault encryption secret (32 chars minimum)
VAULT_SECRET=your_32_char_secret_key_here_1234

# — bot username (without @)
BOT_USERNAME=your_bot_username

# — rate limiting
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW=60

# — session timeout (seconds)
SESSION_TIMEOUT=1800

# — storage limits
# Set to 0 for unlimited (recommended for premium users)
FREE_STORAGE_LIMIT_MB=500
PREMIUM_STORAGE_LIMIT_MB=0
FREE_UPLOAD_LIMIT_MB=20
PREMIUM_UPLOAD_LIMIT_MB=2048

# — backup interval (hours, default 48)
BACKUP_INTERVAL_HOURS=48

# — upi/gpay payment (used in payment instructions)
UPI_ID=xyron@upi
UPI_NAME=Xyron BHIM Pay

# — grok ai (xAI) — free tier gives generous tokens
# Get your API key at https://console.x.ai/
# Leave empty to disable AI assistant
GROK_API_KEY=
