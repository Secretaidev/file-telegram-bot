# ╔══════════════════════════════════════════════════════╗
# ║           VAULT BOT — ENVIRONMENT CONFIG             ║
# ╚══════════════════════════════════════════════════════╝

# — bot credentials
BOT_TOKEN=your_bot_token_here

# — owner & admin ids (comma-separated)
OWNER_ID=123456789
ADMIN_IDS=123456789,987654321

# — mongodb
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/vaultbot
DB_NAME=vaultbot

# — storage channel (private channel where files are stored)
STORAGE_CHANNEL_ID=-1001234567890

# — log channel (private channel for system logs)
LOG_CHANNEL_ID=-1009876543210

# — required join channels (comma-separated usernames without @)
# Leave empty to disable force-join requirement
REQUIRED_CHANNELS=secretsbotz

# — backup channels (comma-separated telegram chat IDs)
# Backup JSON will be sent to ALL of these channels on each scheduled backup.
# You can add up to 2 (or more) channel IDs here, e.g.:
# BACKUP_CHANNEL_IDS=-1001111111111,-1002222222222
BACKUP_CHANNEL_IDS=

# — vault encryption secret (32 chars)
VAULT_SECRET=your_32_char_secret_key_here_1234

# — share link base url (your bot username)
BOT_USERNAME=your_bot_username

# — rate limiting
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW=60

# — session
SESSION_TIMEOUT=1800

# — subscription
FREE_STORAGE_LIMIT_MB=500
PREMIUM_STORAGE_LIMIT_MB=10240
FREE_UPLOAD_LIMIT_MB=20
PREMIUM_UPLOAD_LIMIT_MB=2048

# — backup interval (hours)
BACKUP_INTERVAL_HOURS=24

# — upi/gpay payment
UPI_ID=yourname@gpay
UPI_NAME=Vault Bot Premium
